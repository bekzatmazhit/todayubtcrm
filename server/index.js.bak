import express from "express";
import cors from "cors";
import { initializeDatabase, db } from "./db.js";

const app = express();
const PORT = 3001;

// Middleware
app.use(cors());
app.use(express.json());

// Initialize database
initializeDatabase();

// Routes

// Root endpoint
app.get("/", (req, res) => {
  res.json({
    message: "Today CRM API Server",
    version: "1.0.0",
    endpoints: {
      health: "/api/health",
      users: "/api/users",
      groups: "/api/groups",
      students: "/api/students",
      roles: "/api/roles",
      lessons: "/api/lessons"
    }
  });
});

// Get all users
app.get("/api/users", (req, res) => {
  try {
    console.log("📥 GET /api/users");
    const query = `
      SELECT u.id, u.name, u.surname, u.email, u.phone, r.name as role
      FROM users u
      JOIN roles r ON u.role_id = r.id
      ORDER BY u.id
    `;
    const users = db.prepare(query).all();
    console.log(`✅ Retrieved ${users.length} users`);
    res.json(users);
  } catch (error) {
    console.error("❌ Error fetching users:", error.message);
    res.status(500).json({ error: error.message });
  }
});

// Get user by ID
app.get("/api/users/:id", (req, res) => {
  try {
    const user = db
      .prepare(
        `
      SELECT u.id, u.name, u.surname, u.email, u.phone, r.name as role
      FROM users u
      JOIN roles r ON u.role_id = r.id
      WHERE u.id = ?
    `
      )
      .get(req.params.id);

    if (!user) {
      return res.status(404).json({ error: "User not found" });
    }

    res.json(user);
  } catch (error) {
    res.status(500).json({ error: error.message });
  }
});

// Login endpoint
app.post("/api/login", (req, res) => {
  try {
    const { email, password } = req.body;
    
    if (!email || !password) {
      return res.status(400).json({ error: "Email and password required" });
    }

    console.log(`📥 POST /api/login - Email: ${email}`);

    const user = db
      .prepare(
        `
      SELECT u.id, u.name, u.surname, u.email, u.phone, u.password, r.name as role
      FROM users u
      JOIN roles r ON u.role_id = r.id
      WHERE u.email = ?
    `
      )
      .get(email);

    if (!user) {
      console.log(`❌ User not found: ${email}`);
      return res.status(401).json({ error: "Invalid email or password" });
    }

    if (user.password !== password) {
      console.log(`❌ Wrong password for user: ${email}`);
      return res.status(401).json({ error: "Invalid email or password" });
    }

    console.log(`✅ User logged in: ${email}`);
    res.json({
      id: user.id.toString(),
      email: user.email,
      full_name: `${user.name} ${user.surname}`,
      role: user.role
    });
  } catch (error) {
    console.error("❌ Error during login:", error.message);
    res.status(500).json({ error: error.message });
  }
});

// Get all lessons with students
app.get("/api/lessons", (req, res) => {
  try {
    console.log("📥 GET /api/lessons");
    const { teacher_id } = req.query;
    
    let query = `
      SELECT s.id, s.group_id, s.subject_id, s.teacher_id,
             s.cycle, s.start_time, s.end_time, s.room_name,
             g.name as group_name, 
             subj.name as subject_name,
             u.name || ' ' || u.surname as teacher_name
      FROM schedule s
      LEFT JOIN groups g ON s.group_id = g.id
      LEFT JOIN subjects subj ON s.subject_id = subj.id
      LEFT JOIN users u ON s.teacher_id = u.id
    `;

    if (teacher_id) {
      query += ` WHERE s.teacher_id = ${parseInt(teacher_id)}`;
    }

    query += ` ORDER BY s.start_time`;

    const schedule = db.prepare(query).all();

    // Get students for each group
    const studentsByGroupStmt = db.prepare(`
      SELECT id, full_name, group_id
      FROM students
      WHERE group_id = ?
    `);

    // Helper function to get dates for this week based on cycle
    function generateLessonDates(cycle) {
      const dates = [];
      const today = new Date();
      
      // Generate dates for the past 2 weeks and next 8 weeks (total 10 weeks)
      const startDate = new Date(today);
      startDate.setDate(today.getDate() - 14); // 2 weeks ago
      
      const endDate = new Date(today);
      endDate.setDate(today.getDate() + 56); // 8 weeks ahead
      
      // Map cycle to days (0=Sunday, 1=Monday, 2=Tuesday, etc)
      let lessonDays = [];
      if (cycle === "ПСП") {
        lessonDays = [1, 3, 5]; // Monday, Wednesday, Friday
      } else if (cycle === "ВЧС") {
        lessonDays = [2, 4, 6]; // Tuesday, Thursday, Saturday
      }
      
      // Generate all dates within the range that match the cycle
      for (let d = new Date(startDate); d <= endDate; d.setDate(d.getDate() + 1)) {
        const dayOfWeek = d.getDay();
        if (lessonDays.includes(dayOfWeek)) {
          const dateStr = d.toISOString().split('T')[0];
          dates.push(dateStr);
        }
      }
      
      return dates;
    }

    const result = schedule.map((lesson) => {
      const dates = generateLessonDates(lesson.cycle);
      return {
        id: lesson.id,
        group_id: lesson.group_id,
        subject_id: lesson.subject_id,
        teacher_id: lesson.teacher_id,
        group_name: lesson.group_name,
        subject_name: lesson.subject_name,
        teacher_name: lesson.teacher_name,
        cycle: lesson.cycle,
        start_time: lesson.start_time,
        end_time: lesson.end_time,
        room_name: lesson.room_name,
        dates: dates,
        students: studentsByGroupStmt.all(lesson.group_id),
      };
    });

    console.log(`✅ Retrieved ${result.length} schedule entries`);
    res.json(result);
  } catch (error) {
    console.error("❌ Error fetching lessons:", error.message);
    res.status(500).json({ error: error.message });
  }
});


// Health check
app.get("/api/health", (req, res) => {
  res.json({ status: "ok" });
});

