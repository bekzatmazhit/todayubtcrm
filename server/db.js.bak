function loadStudentsFromCSV(csvPath) {
  try {
    console.log("📂 Loading Students from:", csvPath);
    const data = fs.readFileSync(csvPath, "utf-8");
    const lines = data.split("\n");
    const headers = lines[0].split(",").map((h) => h.trim());

    const idIdx = headers.indexOf("id");
    const nameIdx = headers.indexOf("name");
    const surnameIdx = headers.indexOf("surname");
    const phoneIdx = headers.indexOf("phone");
    const groupIdIdx = headers.indexOf("group_id");
    const statusIdx = headers.indexOf("status");

    const stmt = db.prepare(
      "INSERT INTO students (id, full_name, phone, group_id) VALUES (?, ?, ?, ?)"
    );

    let inserted = 0;
    for (let i = 1; i < lines.length; i++) {
      const line = lines[i].trim();
      if (!line) continue;

      const cols = line.split(",");
      try {
        const fullName = `${cols[nameIdx]?.trim()} ${cols[surnameIdx]?.trim()}`.trim();
        stmt.run(
          parseInt(cols[idIdx]?.trim()),
          fullName,
          cols[phoneIdx]?.trim() || null,
          parseInt(cols[groupIdIdx]?.trim()) || null
        );
        inserted++;
      } catch (e) {
        console.warn(`⚠️ Error inserting student row ${i}:`, e.message);
      }
    }

    console.log(`✅ Inserted ${inserted} students from CSV`);
  } catch (err) {
    console.error("❌ Error loading students CSV:", err.message);
  }
}

function loadScheduleFromCSV(csvPath) {
  try {
    console.log("📂 Loading Schedule from:", csvPath);
    const data = fs.readFileSync(csvPath, "utf-8");
    const lines = data.split("\n");
    const headers = lines[0].split(",").map((h) => h.trim());

    const idIdx = headers.indexOf("id");
    const groupIdIdx = headers.indexOf("group_id");
    const subjectIdIdx = headers.indexOf("subject_id");
    const teacherIdIdx = headers.indexOf("teacher_id");
    const cycleIdx = headers.indexOf("cycle");
    const startTimeIdx = headers.indexOf("start_time");
    const endTimeIdx = headers.indexOf("end_time");
    const roomNameIdx = headers.indexOf("room_name");

    const stmt = db.prepare(`
      INSERT INTO schedule (id, group_id, subject_id, teacher_id, cycle, start_time, end_time, room_name) 
      VALUES (?, ?, ?, ?, ?, ?, ?, ?)
    `);

    let inserted = 0;
    for (let i = 1; i < lines.length; i++) {
      const line = lines[i].trim();
      if (!line) continue;

      const cols = line.split(",");
      try {
        stmt.run(
          parseInt(cols[idIdx]?.trim()),
          parseInt(cols[groupIdIdx]?.trim()),
          parseInt(cols[subjectIdIdx]?.trim()),
          parseInt(cols[teacherIdIdx]?.trim()),
          cols[cycleIdx]?.trim(),
          cols[startTimeIdx]?.trim(),
          cols[endTimeIdx]?.trim(),
          cols[roomNameIdx]?.trim()
        );
        inserted++;
      } catch (e) {
        console.warn(`⚠️ Error inserting schedule row ${i}:`, e.message);
      }
    }

    console.log(`✅ Inserted ${inserted} schedule entries from CSV`);
  } catch (err) {
    console.error("❌ Error loading schedule CSV:", err.message);
  }
}
